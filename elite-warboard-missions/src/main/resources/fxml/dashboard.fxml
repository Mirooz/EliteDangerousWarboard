<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="be.mirooz.elitedangerous.dashboard.view.main.DashboardController">
    <center>
        <StackPane fx:id="popupContainer">
            <VBox styleClass="dashboard-root">
                <HBox fx:id="dashboardTitleBar" alignment="CENTER_LEFT" spacing="16.0" styleClass="title-bar">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <Label fx:id="appTitleLabel" styleClass="app-title" text="ELITE DANGEROUS"/>
                            <Label fx:id="appSubtitleLabel" styleClass="app-subtitle" text="DASHBOARD DES MISSIONS"/>
                        </HBox>
                        <Region minWidth="8.0" HBox.hgrow="ALWAYS"/>
                        <!-- Commander / Système / Station : même espacement entre les trois blocs -->
                        <HBox alignment="CENTER" spacing="28.0" styleClass="dashboard-status-strip">
                            <VBox alignment="CENTER" spacing="2.0" minWidth="120.0" prefWidth="160.0" maxWidth="220.0">
                                <Label fx:id="commanderHeaderLabel" styleClass="footer-text" text="COMMANDANT"
                                       maxWidth="Infinity" alignment="CENTER"/>
                                <Label fx:id="commanderLabel" styleClass="footer-value" text="[NOM DU COMMANDANT]"
                                       maxWidth="Infinity" alignment="CENTER"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="2.0" minWidth="200.0" prefWidth="280.0" maxWidth="480.0"
                                   HBox.hgrow="SOMETIMES">
                                <Label fx:id="systemHeaderLabel" styleClass="footer-text" text="SYSTÈME"
                                       maxWidth="Infinity" alignment="CENTER"/>
                                <Label fx:id="systemLabel" styleClass="footer-value clickable-system-source"
                                       text="[NON IDENTIFIÉ]" maxWidth="Infinity" alignment="CENTER"
                                       onMouseClicked="#onSystemLabelClicked"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="2.0" minWidth="120.0" prefWidth="160.0" maxWidth="220.0">
                                <Label fx:id="stationHeaderLabel" styleClass="footer-text" text="STATION"
                                       maxWidth="Infinity" alignment="CENTER"/>
                                <Label fx:id="stationLabel" styleClass="footer-value" text="[NON IDENTIFIÉE]"
                                       maxWidth="Infinity" alignment="CENTER"/>
                            </VBox>
                        </HBox>
                        <Region minWidth="8.0" HBox.hgrow="ALWAYS"/>
                        <ImageView fx:id="donateButtonImage"
                                   fitHeight="58"
                                   preserveRatio="true"
                                   smooth="true"
                                   styleClass="donate-button-image"
                                   onMouseClicked="#openDonateLink"/>
                        <Label fx:id="statusLabel" styleClass="status-label"/>
                        <Button fx:id="configButton" mnemonicParsing="false" onAction="#openConfigDialog"
                                styleClass="config-button" text="⚙"/>
                        <HBox alignment="CENTER_RIGHT" spacing="0.0" styleClass="window-control-box">
                            <Button fx:id="windowMinimizeButton" mnemonicParsing="false" onAction="#onWindowMinimize"
                                    styleClass="window-control-btn,window-control-min"/>
                            <Button fx:id="windowMaxRestoreButton" mnemonicParsing="false" onAction="#onWindowMaxRestoreToggle"
                                    styleClass="window-control-btn,window-control-max"/>
                            <Button fx:id="windowCloseButton" mnemonicParsing="false" onAction="#onWindowClose"
                                    styleClass="window-control-btn,window-control-close"/>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="12.0" top="10.0"/>
                    </padding>
                </HBox>
                <Separator styleClass="header-separator"/>

                <!-- TabPane + bouton tutoriel (overlay TOP_CENTER, taille pref : pas d’étirement plein écran). -->
                <StackPane VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                    <TabPane fx:id="mainTabPane" styleClass="main-tab-pane" maxWidth="Infinity" maxHeight="Infinity">
                    <!-- Onglet Missions -->
                    <Tab fx:id="missionsTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="missionsTabImage" styleClass="tab-image" />
                        </graphic>
                        <StackPane fx:id="missionsTabStackHost" maxWidth="Infinity" maxHeight="Infinity">
                            <BorderPane fx:id="missionsPane" maxWidth="Infinity" maxHeight="Infinity" styleClass="main-content" />
                        </StackPane>
                    </Tab>
                    
                    <!-- Onglet Mining -->
                    <Tab fx:id="miningTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="miningTabImage" styleClass="tab-image" />
                        </graphic>
                        <BorderPane fx:id="miningPane" styleClass="main-content" />
                    </Tab>
                    
                    <!-- Onglet Exploration -->
                    <Tab fx:id="explorationTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="explorationTabImage" styleClass="tab-image" />
                        </graphic>
                        <BorderPane fx:id="explorationPane" styleClass="main-content" />
                    </Tab>

                    <!-- Onglet Colonisation & Fleet Carrier -->
                    <Tab fx:id="colonisationTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="colonisationTabImage" styleClass="tab-image" />
                        </graphic>
                        <BorderPane fx:id="colonisationPane" styleClass="main-content" />
                    </Tab>
                    </TabPane>
                    <Button fx:id="globalModuleTutorialButton" mnemonicParsing="false" onAction="#onGlobalModuleTutorialClicked"
                            styleClass="tutorial-global-bar-button" text="Tutorial" maxHeight="-1.0" maxWidth="-1.0"
                            StackPane.alignment="TOP_CENTER">
                        <StackPane.margin>
                            <Insets top="16.0"/>
                        </StackPane.margin>
                    </Button>
                </StackPane>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
