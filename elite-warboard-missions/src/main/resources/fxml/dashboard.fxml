<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="be.mirooz.elitedangerous.dashboard.view.main.DashboardController">
    <center>
        <StackPane fx:id="popupContainer">
            <VBox>
                <HBox fx:id="windowChromeBar" alignment="CENTER_LEFT" minHeight="32.0" prefHeight="32.0" maxHeight="32.0"
                      spacing="0.0" styleClass="window-chrome">
                    <padding>
                        <Insets bottom="0.0" left="12.0" right="0.0" top="0.0"/>
                    </padding>
                    <!-- Zone titre + espace : seuls ces nœuds reçoivent le drag (pas les boutons à droite). -->
                    <HBox fx:id="windowChromeLeft" alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS"
                          styleClass="window-chrome-left">
                        <Label fx:id="windowChromeTitleLabel" styleClass="window-chrome-title" text="Elite Dangerous Warboard"/>
                        <Region HBox.hgrow="ALWAYS" minWidth="0.0"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="0.0" styleClass="window-control-box">
                        <Button fx:id="windowMinimizeButton" mnemonicParsing="false" onAction="#onWindowMinimize"
                                styleClass="window-control-btn,window-control-min"/>
                        <Button fx:id="windowMaxRestoreButton" mnemonicParsing="false" onAction="#onWindowMaxRestoreToggle"
                                styleClass="window-control-btn,window-control-max"/>
                        <Button fx:id="windowCloseButton" mnemonicParsing="false" onAction="#onWindowClose"
                                styleClass="window-control-btn,window-control-close"/>
                    </HBox>
                </HBox>
                <HBox fx:id="dashboardTitleBar" alignment="CENTER_LEFT" spacing="20.0" styleClass="title-bar">
                    <children>
                        <Label fx:id="appTitleLabel" styleClass="app-title" text="ELITE DANGEROUS"/>
                        <Label fx:id="appSubtitleLabel" styleClass="app-subtitle" text="DASHBOARD DES MISSIONS"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <!-- Commander, System, Station au centre -->
                        <VBox alignment="CENTER" spacing="2.0">
                            <HBox alignment="CENTER" spacing="10.0">
                                <Label fx:id="commanderHeaderLabel" styleClass="footer-text" text="COMMANDANT" prefWidth="140" alignment="CENTER"/>
                                <Label styleClass="footer-text" text="|"/>
                                <Label fx:id="systemHeaderLabel" styleClass="footer-text" text="SYSTÈME" prefWidth="280" alignment="CENTER"/>
                                <Label styleClass="footer-text" text="|"/>
                                <Label fx:id="stationHeaderLabel" styleClass="footer-text" text="STATION" prefWidth="160" alignment="CENTER"/>
                            </HBox>
                            <HBox alignment="CENTER" spacing="10.0">
                                <Label fx:id="commanderLabel" styleClass="footer-value" text="[NOM DU COMMANDANT]" prefWidth="140" alignment="CENTER"/>
                                <Label styleClass="footer-text" text="|"/>
                                <Label fx:id="systemLabel" styleClass="footer-value clickable-system-source" text="[NON IDENTIFIÉ]" prefWidth="280" minWidth="280" alignment="CENTER" onMouseClicked="#onSystemLabelClicked"/>
                                <Label styleClass="footer-text" text="|"/>
                                <Label fx:id="stationLabel" styleClass="footer-value" text="[NON IDENTIFIÉE]" prefWidth="160" alignment="CENTER"/>
                            </HBox>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ImageView fx:id="donateButtonImage"
                                   fitHeight="58"
                                   preserveRatio="true"
                                   smooth="true"
                                   styleClass="donate-button-image"
                                   onMouseClicked="#openDonateLink"/>
                        <Label fx:id="statusLabel" styleClass="status-label"/>
                        <Button fx:id="configButton" mnemonicParsing="false" onAction="#openConfigDialog"
                                styleClass="config-button" text="⚙"/>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="12.0" top="10.0"/>
                    </padding>
                </HBox>
                <Separator styleClass="header-separator"/>

                <!-- Conteneur principal avec onglets -->
                <TabPane fx:id="mainTabPane" styleClass="main-tab-pane" VBox.vgrow="ALWAYS">
                    <!-- Onglet Missions -->
                    <Tab fx:id="missionsTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="missionsTabImage" styleClass="tab-image" />
                        </graphic>
                        <StackPane fx:id="missionsTabStackHost" maxWidth="Infinity" maxHeight="Infinity">
                            <BorderPane fx:id="missionsPane" maxWidth="Infinity" maxHeight="Infinity" styleClass="main-content" />
                        </StackPane>
                    </Tab>
                    
                    <!-- Onglet Mining -->
                    <Tab fx:id="miningTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="miningTabImage" styleClass="tab-image" />
                        </graphic>
                        <BorderPane fx:id="miningPane" styleClass="main-content" />
                    </Tab>
                    
                    <!-- Onglet Exploration -->
                    <Tab fx:id="explorationTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="explorationTabImage" styleClass="tab-image" />
                        </graphic>
                        <BorderPane fx:id="explorationPane" styleClass="main-content" />
                    </Tab>

                    <!-- Onglet Colonisation & Fleet Carrier -->
                    <Tab fx:id="colonisationTab" style="-fx-cursor: hand">
                        <graphic>
                            <ImageView fx:id="colonisationTabImage" styleClass="tab-image" />
                        </graphic>
                        <BorderPane fx:id="colonisationPane" styleClass="main-content" />
                    </Tab>
                </TabPane>
            </VBox>
        </StackPane>
    </center>
</BorderPane>