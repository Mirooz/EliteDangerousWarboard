<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="be.mirooz.elitedangerous.dashboard.view.colonisation.ColonisationPanelController"
      styleClass="colonisation-panel" spacing="10">
    <VBox fx:id="architectViewRoot" spacing="10.0" VBox.vgrow="ALWAYS">
        <HBox spacing="10.0" VBox.vgrow="ALWAYS" alignment="TOP_LEFT" styleClass="colonisation-split">
            <VBox spacing="10.0" styleClass="colonisation-column" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" minHeight="160.0">
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label fx:id="constructionsTitleLabel" styleClass="mining-title"/>
                    <ComboBox fx:id="architectSystemComboBox" minWidth="140.0" prefWidth="260.0" maxWidth="300.0"
                              HBox.hgrow="NEVER" styleClass="colonisation-architect-system-combo"/>
                    <Label fx:id="architectSystemStatsLabel" wrapText="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                           styleClass="colonisation-architect-system-stats"/>
                </HBox>
                <TabPane fx:id="architectCenterTabPane" styleClass="colonisation-tab-pane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <Tab fx:id="architectSystemViewTab">
                            <VBox spacing="0.0" VBox.vgrow="ALWAYS">
                                <VBox fx:id="architectMapContainer" VBox.vgrow="ALWAYS"/>
                            </VBox>
                        </Tab>
                        <Tab fx:id="architectCargoFleetTab">
                            <VBox spacing="0.0" styleClass="colonisation-fleet-tab-wrap" VBox.vgrow="ALWAYS">
                            <HBox spacing="10.0" VBox.vgrow="ALWAYS">
                                <VBox spacing="8.0" styleClass="colonisation-fleet-carrier-column" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                                        <Label fx:id="fleetTitleLabel" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="mining-title"/>
                                        <Button fx:id="fleetCarrierOverlayButton" mnemonicParsing="false" focusTraversable="false"
                                                styleClass="elite-nav-button"/>
                                        <ToggleButton fx:id="fleetCarrierOverlayLockButton" mnemonicParsing="false" focusTraversable="false"
                                                      styleClass="elite-nav-button overlay-pass-through-lock"/>
                                        <Button fx:id="fleetCollapseButton" mnemonicParsing="false" focusTraversable="false" managed="false" visible="false"
                                                styleClass="colonisation-panel-fold-button" text="▼"/>
                                    </HBox>
                                    <VBox fx:id="fleetCollapsibleContent" spacing="0.0" VBox.vgrow="ALWAYS">
                                        <VBox fx:id="fleetSummaryBox" spacing="4.0"/>
                                        <VBox spacing="0.0" styleClass="colonisation-fleet-merged-frame" VBox.vgrow="ALWAYS">
                                            <ScrollPane fx:id="fleetMarketScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                        styleClass="cargo-minerals-scroll,colonisation-fleet-market-scroll" VBox.vgrow="ALWAYS">
                                                <VBox spacing="6.0" maxWidth="Infinity" styleClass="colonisation-fleet-scroll-inner">
                                                    <GridPane fx:id="fleetMarketGrid" styleClass="cargo-minerals-grid,colonisation-fleet-market-grid">
                                                        <columnConstraints>
                                                            <ColumnConstraints hgrow="ALWAYS"/>
                                                            <ColumnConstraints hgrow="SOMETIMES"/>
                                                            <ColumnConstraints hgrow="SOMETIMES"/>
                                                            <ColumnConstraints hgrow="SOMETIMES"/>
                                                            <ColumnConstraints hgrow="SOMETIMES"/>
                                                            <ColumnConstraints hgrow="SOMETIMES"/>
                                                        </columnConstraints>
                                                    </GridPane>
                                                </VBox>
                                            </ScrollPane>
                                        </VBox>
                                    </VBox>
                                </VBox>
                                <VBox fx:id="fleetOptimalMarketPanel" spacing="8.0" styleClass="colonisation-fleet-optimal-column"
                                      prefWidth="400.0" maxWidth="560.0" HBox.hgrow="SOMETIMES" VBox.vgrow="ALWAYS">
                                    <HBox spacing="8.0" alignment="CENTER_LEFT" styleClass="colonisation-fleet-optimal-toolbar">
                                        <Button fx:id="fleetFindOptimalMarketButton" mnemonicParsing="false" focusTraversable="false"
                                                styleClass="elite-nav-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <Button fx:id="fleetOptimalMarketHelpButton" mnemonicParsing="false" focusTraversable="false"
                                                styleClass="nav-route-info-button" minWidth="24.0" maxWidth="24.0" minHeight="24.0" maxHeight="24.0">
                                            <graphic>
                                                <Label text="?" styleClass="nav-route-info-icon"/>
                                            </graphic>
                                        </Button>
                                        <ProgressIndicator fx:id="fleetOptimalMarketProgress" prefWidth="32.0" prefHeight="32.0"
                                                           minWidth="32.0" minHeight="32.0" maxWidth="32.0" maxHeight="32.0"
                                                           visible="false" managed="false"/>
                                    </HBox>
                                    <CheckBox fx:id="fleetAvoidPlanetaryLandingCheckBox" wrapText="true" maxWidth="Infinity"
                                              styleClass="fleet-carrier-checkbox" selected="true"/>
                                    <CheckBox fx:id="fleetLargePadOnlyCheckBox" text="Large pads" wrapText="true" maxWidth="Infinity"
                                              styleClass="fleet-carrier-checkbox" selected="true"/>
                                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                styleClass="cargo-minerals-scroll,colonisation-fleet-market-scroll,colonisation-fleet-merged-frame"
                                                VBox.vgrow="ALWAYS">
                                        <VBox fx:id="fleetOptimalMarketResultsBox" spacing="10.0" maxWidth="Infinity"
                                              styleClass="colonisation-fleet-optimal-results"/>
                                    </ScrollPane>
                                </VBox>
                                <VBox fx:id="fleetRightColumn" spacing="8.0" styleClass="colonisation-fleet-commander-column" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                                        <Label fx:id="commanderCurrentCargoTitleLabel" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="mining-title"/>
                                        <Button fx:id="commanderCollapseButton" mnemonicParsing="false" focusTraversable="false" managed="false" visible="false"
                                                styleClass="colonisation-panel-fold-button" text="▼"/>
                                    </HBox>
                                    <VBox fx:id="commanderCollapsibleContent" spacing="0.0" VBox.vgrow="ALWAYS">
                                        <VBox spacing="6.0" styleClass="colonisation-buy-station-wrap,colonisation-fleet-commander-cargo-inner" VBox.vgrow="ALWAYS">
                                            <HBox spacing="8.0" alignment="CENTER_LEFT" managed="false" visible="false"
                                                  styleClass="colonisation-commander-cargo-summary,cargo-info,colonisation-fleet-cargo-info">
                                                <ProgressBar fx:id="commanderCargoProgressBar" styleClass="progress-bar" prefWidth="120.0" prefHeight="8.0" HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="commanderCargoUsedLabel" styleClass="colonisation-commander-cargo-used"/>
                                            </HBox>
                                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                        styleClass="cargo-minerals-scroll,colonisation-fleet-market-scroll,colonisation-fleet-merged-frame" VBox.vgrow="ALWAYS">
                                                <VBox fx:id="commanderColonyVBox" spacing="10.0" maxWidth="Infinity"
                                                      styleClass="colonisation-fleet-colony-root"/>
                                            </ScrollPane>
                                        </VBox>
                                    </VBox>
                                </VBox>
                            </HBox>
                            </VBox>
                        </Tab>
                        <Tab fx:id="architectColonisableSearchTab">
                            <VBox spacing="8.0" styleClass="colonisation-finder-root" VBox.vgrow="ALWAYS">
                                <BorderPane styleClass="colonisation-column,colonisation-search-pane" VBox.vgrow="ALWAYS">
                                    <left>
                                        <VBox spacing="12.0" maxWidth="420.0" styleClass="colonisation-search-filters" BorderPane.alignment="CENTER_LEFT">
                                            <padding>
                                                <Insets top="10.0" right="10.0" bottom="10.0" left="4.0"/>
                                            </padding>
                                            <VBox spacing="8.0" maxWidth="Infinity">
                                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                    <VBox spacing="4.0" prefWidth="132.0">
                                                        <Label fx:id="searchMinLandablesLabel" styleClass="config-label" wrapText="true"/>
                                                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                                                            <Label text="≥" styleClass="edcolonise-filter-geq"/>
                                                            <Spinner fx:id="searchMinLandablesSpinner" editable="true" min="0" max="61" initialValue="0" prefWidth="92"
                                                                     styleClass="config-spinner"/>
                                                        </HBox>
                                                    </VBox>
                                                    <VBox spacing="4.0" prefWidth="132.0">
                                                        <Label fx:id="searchMinRingsLabel" styleClass="config-label" wrapText="true"/>
                                                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                                                            <Label text="≥" styleClass="edcolonise-filter-geq"/>
                                                            <Spinner fx:id="searchMinRingsSpinner" editable="true" min="0" max="26" initialValue="0" prefWidth="92"
                                                                     styleClass="config-spinner"/>
                                                        </HBox>
                                                    </VBox>
                                                    <VBox spacing="4.0" prefWidth="108.0" maxWidth="108.0">
                                                        <Label fx:id="searchMaxDistanceSolLabel" styleClass="config-label" wrapText="true"/>
                                                        <Spinner fx:id="searchMaxDistanceSolSpinner" editable="true" min="1" max="2770" initialValue="800" prefWidth="100"
                                                                 styleClass="config-spinner"/>
                                                    </VBox>
                                                    <VBox alignment="BOTTOM_LEFT">
                                                        <Button fx:id="searchHelpButton" mnemonicParsing="false" focusTraversable="false"
                                                                styleClass="nav-route-info-button" minWidth="24.0" maxWidth="24.0" minHeight="24.0" maxHeight="24.0">
                                                            <graphic>
                                                                <Label text="?" styleClass="nav-route-info-icon"/>
                                                            </graphic>
                                                        </Button>
                                                    </VBox>
                                                </HBox>
                                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                    <Button fx:id="searchMoreFiltersButton" mnemonicParsing="false" styleClass="elite-nav-button"/>
                                                    <Region HBox.hgrow="ALWAYS"/>
                                                    <ProgressIndicator fx:id="searchLoadingIndicator" maxHeight="30.0" maxWidth="30.0" visible="false"/>
                                                    <Button fx:id="searchColonisableButton" styleClass="elite-nav-button"/>
                                                </HBox>
                                            </VBox>
                                            <Label fx:id="searchErrorLabel" styleClass="footer-text" wrapText="true" visible="false" managed="false"/>
                                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                        styleClass="colonisation-architect-scroll,colonisation-detail-scroll" VBox.vgrow="ALWAYS">
                                                <VBox fx:id="searchResultsBox" spacing="10.0" styleClass="colonisation-search-results-box">
                                                    <padding>
                                                        <Insets top="4.0" right="4.0" bottom="8.0" left="4.0"/>
                                                    </padding>
                                                </VBox>
                                            </ScrollPane>
                                        </VBox>
                                    </left>
                                    <center>
                                        <VBox spacing="0.0" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <VBox fx:id="searchMapContainer" VBox.vgrow="ALWAYS"/>
                                        </VBox>
                                    </center>
                                </BorderPane>
                            </VBox>
                        </Tab>
                    </tabs>
                </TabPane>
            </VBox>
            <VBox spacing="8.0" maxWidth="520.0" prefWidth="480.0" HBox.hgrow="NEVER"
                  styleClass="colonisation-column,colonisation-detail-column" VBox.vgrow="ALWAYS">
                <Label fx:id="constructionDetailTitleLabel" styleClass="mining-title"/>
                <Label fx:id="statusLabel" styleClass="footer-text" wrapText="true" maxWidth="496.0"/>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            styleClass="colonisation-architect-scroll,colonisation-detail-scroll" VBox.vgrow="ALWAYS">
                    <VBox fx:id="constructionDetailContent" spacing="10.0">
                        <padding>
                            <Insets top="4.0" right="4.0" bottom="8.0" left="4.0"/>
                        </padding>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </VBox>
</VBox>
