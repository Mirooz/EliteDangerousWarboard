<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import be.mirooz.elitedangerous.dashboard.view.common.NotSelectableListView?>
<?import be.mirooz.elitedangerous.dashboard.model.commander.Mission?>
<?import be.mirooz.elitedangerous.dashboard.view.combat.TargetPanelComponent?>
<StackPane fx:id="missionListRoot" styleClass="mission-list-root" xmlns="http://javafx.com/javafx/11.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="be.mirooz.elitedangerous.dashboard.view.combat.MissionListController">
   <VBox fx:id="missionContentVBox" spacing="10.0" styleClass="missions-container" maxWidth="Infinity" maxHeight="Infinity">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
   </padding>
   <HBox fx:id="missionsHeaderRow" alignment="CENTER_LEFT" spacing="20.0">
      <Label fx:id="missionsTitleLabel" styleClass="section-title" text="MISSIONS"/>
      <Region HBox.hgrow="ALWAYS"/>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <Label fx:id="typeFilterLabel" styleClass="filter-label" text="Type:"/>
         <ComboBox fx:id="typeFilterComboBox" styleClass="elite-combobox" onAction="#onTypeFilterChanged"/>
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <Label fx:id="statusFilterLabel" styleClass="filter-label" text="Statut:"/>
         <ComboBox fx:id="statusFilterComboBox" styleClass="elite-combobox" onAction="#onStatusFilterChanged"/>
      </HBox>
      <Button fx:id="missionTutorialButton" mnemonicParsing="false" onAction="#onMissionTutorialClicked"
              styleClass="tutorial-launch-button" text="?"/>
   </HBox>

   <!-- Layout principal avec missions à gauche et cibles à droite -->
   <HBox spacing="20.0" VBox.vgrow="ALWAYS">
      <!-- Section des missions (gauche) -->
      <VBox fx:id="missionsListColumn" HBox.hgrow="ALWAYS" spacing="10.0" minWidth="400">
         <StackPane VBox.vgrow="ALWAYS" minHeight="200">
            <NotSelectableListView fx:id="missionListView"
                                   styleClass="missions-scroll"
                                   minWidth="400" minHeight="200" />

            <ProgressIndicator fx:id="loadingIndicator"
                               maxWidth="100" maxHeight="100"
                               visible="false" />
         </StackPane>
      </VBox>

      <!-- Section des cibles (droite) : largeur min plus confortable pour noms de faction + kills -->
      <VBox HBox.hgrow="NEVER" spacing="10.0" minWidth="360" maxWidth="560">
         <TargetPanelComponent fx:id="targetPanel"
                              styleClass="target-panel-compact"
                              minWidth="320"
                              maxWidth="560"
                              prefHeight="280"
                              maxHeight="320"
                              VBox.vgrow="NEVER"/>
         
         <!-- Historique des missions -->
         <VBox fx:id="historyContainer" VBox.vgrow="ALWAYS" spacing="10.0">
         </VBox>
      </VBox>
   </HBox>

   </VBox>
</StackPane>
