<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/11.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="be.mirooz.elitedangerous.dashboard.view.main.ConfigDialogController"
           styleClass="config-dialog"
           alignment="TOP_CENTER"
           maxWidth="Infinity"
           maxHeight="Infinity">

    <VBox spacing="0.0" styleClass="config-content" maxWidth="760.0" maxHeight="Infinity">
        <padding>
            <Insets bottom="8.0" left="14.0" right="14.0" top="10.0"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="config-header">
            <VBox spacing="2.0">
                <Label fx:id="configTitleLabel" text="CONFIGURATION" styleClass="config-title"/>
                <Label fx:id="configSubtitleLabel" text="Paramètres de l'application" styleClass="config-subtitle"/>
            </VBox>
        </HBox>

        <TabPane styleClass="colonisation-tab-pane,config-dialog-tab-nav"
                 tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" maxHeight="Infinity">

            <Tab fx:id="preferencesTab" closable="false" text="Preferences">
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="false"
                            styleClass="config-settings-scroll,config-dialog-tab-scroll" maxWidth="Infinity" maxHeight="Infinity">
                    <VBox spacing="12.0" styleClass="config-settings-scroll-inner" fillWidth="true">
                        <padding>
                            <Insets bottom="8.0" top="4.0"/>
                        </padding>

                        <VBox spacing="4.0" styleClass="config-section-compact">
                            <Label fx:id="languageSectionLabel" text="LANGUE" styleClass="config-section-title"/>
                            <ComboBox fx:id="languageComboBox" styleClass="config-combo" prefWidth="240.0"/>
                        </VBox>

                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="6.0" styleClass="config-section-compact">
                            <Label fx:id="journalFolderSectionLabel" text="DOSSIER JOURNAL" styleClass="config-section-title"/>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <TextField fx:id="journalFolderTextField" styleClass="config-textfield"
                                           promptText="Chemin vers le dossier Journal Elite Dangerous" HBox.hgrow="ALWAYS"/>
                                <Button fx:id="browseJournalFolderButton" text="Parcourir..."
                                        onAction="#browseJournalFolder" styleClass="elite-button"/>
                            </HBox>
                            <Label fx:id="journalFolderDescriptionLabel" text=""
                                   styleClass="config-description" maxWidth="Infinity" wrapText="true"/>
                            <Button fx:id="reloadAllCommanderFilesButton" text="Reload all log files"
                                    onAction="#reloadAllCommanderFiles" styleClass="elite-button-secondary"/>
                        </VBox>

                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="6.0" styleClass="config-section-compact">
                            <CheckBox fx:id="sendDataToEddnCheckBox" text="Send datas to EDDN"
                                      styleClass="config-checkbox"/>
                            <CheckBox fx:id="sendErrorLogsCheckBox" text="Send error logs"
                                      styleClass="config-checkbox"/>
                            <CheckBox fx:id="capiLoginEnabledCheckBox" text="Connect Frontier Companion API"
                                      onAction="#onCapiLoginEnabledChanged" styleClass="config-checkbox"/>
                            <HBox fx:id="capiStatusRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="config-capi-status-row" visible="false" managed="false">
                                <Label fx:id="capiStatusIconLabel" styleClass="config-capi-status-icon" text=""/>
                                <Label fx:id="capiStatusTextLabel" styleClass="config-capi-status-text" wrapText="true" maxWidth="Infinity"/>
                            </HBox>
                            <Button fx:id="logCapiAccountButton" text="Connect Frontier Companion API"
                                    onAction="#logCapiAccount" styleClass="elite-button-secondary"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab fx:id="gameplayTab" closable="false" text="Gameplay">
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="false"
                            styleClass="config-settings-scroll,config-dialog-tab-scroll" maxWidth="Infinity" maxHeight="Infinity">
                    <VBox spacing="12.0" styleClass="config-settings-scroll-inner" fillWidth="true">
                        <padding>
                            <Insets bottom="8.0" top="4.0"/>
                        </padding>

                        <VBox spacing="4.0" styleClass="config-section-compact">
                            <Label fx:id="explorationDataSectionLabel" text="Exploration" styleClass="config-section-title"/>
                            <CheckBox fx:id="spanshLoadSystemsCheckBox" text="Load systems via Spansh"
                                      styleClass="config-checkbox"/>
                        </VBox>

                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="10.0" styleClass="config-combat-outer">
                            <Label fx:id="combatSectionLabel" text="COMBAT" styleClass="config-section-title"/>
                            <VBox spacing="8.0" styleClass="config-combat-inner">
                                <CheckBox fx:id="combatAutoPowerplantCheckBox" text="Select powerplant automatically"
                                          styleClass="config-checkbox" wrapText="true" maxWidth="Infinity"
                                          onAction="#onCombatAutoPowerplantChanged"/>
                                <VBox fx:id="combatBindSectionContainer" spacing="8.0">
                                    <Label fx:id="combatSubsystemKeyboardHintLabel" styleClass="config-description"
                                           wrapText="true" maxWidth="Infinity" text=""/>
                                    <VBox spacing="8.0" styleClass="config-bind-strip">
                                    <Label fx:id="combatSubsystemBindLabel" text="Next subsystem:"
                                           styleClass="config-bind-strip-caption" wrapText="true" maxWidth="Infinity"/>
                                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="config-bind-actions">
                                        <Button fx:id="combatSubsystemBindButton" text="BIND"
                                                onAction="#captureCombatSubsystemBind" styleClass="elite-button,config-bind-capture-btn" minWidth="72.0"/>
                                        <Label fx:id="combatSubsystemBindValueLabel" styleClass="config-bind-value-chip"
                                               text="No bind" minWidth="56.0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="combatSubsystemUnbindButton" mnemonicParsing="false" contentDisplay="GRAPHIC_ONLY"
                                                onAction="#unbindCombatSubsystem" styleClass="elite-button-secondary,config-bind-clear-btn"
                                                visible="false" managed="false">
                                            <graphic>
                                                <Label text="×" styleClass="config-bind-clear-x"/>
                                            </graphic>
                                        </Button>
                                    </HBox>
                                    </VBox>
                                </VBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab fx:id="vrOverlayTab" closable="false" text="VR">
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="false"
                            styleClass="config-settings-scroll,config-dialog-tab-scroll" maxWidth="Infinity" maxHeight="Infinity">
                    <VBox spacing="12.0" styleClass="config-settings-scroll-inner" fillWidth="true">
                        <padding>
                            <Insets bottom="8.0" top="4.0"/>
                        </padding>

                        <VBox spacing="10.0" styleClass="config-vr-outer">
                            <CheckBox fx:id="vrModeEnabledCheckBox" text="Enable VR mode"
                                      onAction="#onVrModeChanged" styleClass="config-checkbox" wrapText="true" maxWidth="Infinity" disable="true"/>
                            <VBox fx:id="vrBindSectionContainer" spacing="10.0">
                            <Label fx:id="vrBindingsFootnoteLabel" styleClass="config-description" wrapText="true" maxWidth="Infinity" text=""/>

                            <VBox spacing="8.0" styleClass="config-bind-strip">
                                <Label fx:id="windowToggleBindLabel" text="Hide/Show Dashboard:"
                                       styleClass="config-bind-strip-caption" wrapText="true" maxWidth="Infinity"/>
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="config-bind-actions">
                                    <Button fx:id="windowToggleBindButton" text="BIND"
                                            onAction="#captureWindowToggleBind" styleClass="elite-button,config-bind-capture-btn" minWidth="72.0"/>
                                    <Label fx:id="windowToggleBindValueLabel" styleClass="config-bind-value-chip"
                                           text="Aucun bind" minWidth="56.0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="windowToggleUnbindButton" mnemonicParsing="false" contentDisplay="GRAPHIC_ONLY"
                                            onAction="#unbindWindowToggle" styleClass="elite-button-secondary,config-bind-clear-btn"
                                            visible="false" managed="false">
                                        <graphic>
                                            <Label text="×" styleClass="config-bind-clear-x"/>
                                        </graphic>
                                    </Button>
                                </HBox>
                            </VBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>
        </TabPane>

        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="config-action-panel">
            <Button fx:id="saveButton" mnemonicParsing="false" onAction="#saveConfig"
                    styleClass="elite-button" text="SAUVEGARDER"/>
            <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancelConfig"
                    styleClass="elite-button-secondary" text="ANNULER"/>
        </HBox>
    </VBox>

</StackPane>
