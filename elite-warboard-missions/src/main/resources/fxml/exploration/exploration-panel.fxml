<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="be.mirooz.elitedangerous.dashboard.view.exploration.ExplorationController"
      styleClass="exploration-panel" spacing="10">

    <!-- Panel de route de navigation (toujours affiché) -->
    <fx:include source="nav-route.fxml"/>

    <!-- Zone principale : liste des corps (gauche) + vue système (centre) + historique (droite) -->
    <HBox spacing="20" styleClass="exploration-content" VBox.vgrow="ALWAYS">

        <!-- Colonne corps du système (déplacée depuis system-visual-view au chargement) -->
        <VBox fx:id="systemBodiesListWrapper" spacing="0" styleClass="exploration-bodies-list-column"
              minWidth="400" prefWidth="480" maxWidth="480" HBox.hgrow="NEVER" VBox.vgrow="ALWAYS"/>

        <!-- Vue visuelle du système (titre + orrery, sans la liste des corps) -->
        <VBox fx:id="systemVisualViewContainer" spacing="10" styleClass="exploration-visual-view" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"/>

        <!-- Historique avec navigation + liste des systèmes visités -->
        <VBox fx:id="explorationHistoryDetailContainer" spacing="10" VBox.vgrow="ALWAYS"/>

    </HBox>
</VBox>

