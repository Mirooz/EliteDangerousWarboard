<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.Group?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="be.mirooz.elitedangerous.dashboard.view.exploration.SystemVisualViewComponent"
      spacing="0" styleClass="exploration-visual-view" VBox.vgrow="ALWAYS">

    <Label fx:id="systemTitleLabel" text="VUE VISUELLE DU SYSTÈME" styleClass="exploration-section-title" />
    
    <!-- Conteneur principal : Panneau gauche + Vue visuelle (panneau JSON en overlay sur la vue centrale) -->
    <HBox spacing="10" VBox.vgrow="ALWAYS">
        <!-- Panneau gauche : Liste des corps du système -->
        <VBox fx:id="bodiesListPanel" styleClass="exploration-bodies-list-panel" spacing="4"
              minWidth="400" prefWidth="480" maxWidth="480" HBox.hgrow="NEVER" VBox.vgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT" styleClass="exploration-bodies-list-toolbar">
                <Label fx:id="systemBodiesLabel" text="CORPS DU SYSTÈME"
                       styleClass="exploration-bodies-list-section-title"
                       minWidth="0"/>
                <Button fx:id="systemBodiesHelpButton" mnemonicParsing="false" focusTraversable="false"
                        styleClass="nav-route-info-button" minWidth="24.0" maxWidth="24.0" minHeight="24.0" maxHeight="24.0">
                    <graphic>
                        <Label text="?" styleClass="nav-route-info-icon"/>
                    </graphic>
                </Button>
                <Region minWidth="8" HBox.hgrow="ALWAYS"/>
                <HBox spacing="4" alignment="CENTER_RIGHT">
                    <Button fx:id="bodiesOverlayButton" styleClass="elite-nav-button" onAction="#showBodiesOverlay"/>
                    <ToggleButton fx:id="bodiesOverlayPassThroughLockButton" mnemonicParsing="false" focusTraversable="false"
                                  styleClass="elite-nav-button overlay-pass-through-lock"/>
                </HBox>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="exploration-bodies-filter-row">
                <ToggleButton fx:id="showOnlyHighValueBodiesToggle" mnemonicParsing="false" focusTraversable="true"
                              styleClass="exploration-bodies-filter-toggle"/>
                <Label fx:id="showOnlyHighValueBodiesLabel" text="Show only high value bodies"
                       styleClass="exploration-bodies-filter-label" wrapText="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
            <!-- Radar exobio : rempli en code ; visible uniquement pendant l’analyse biologique (Status.json) -->
            <VBox fx:id="exobioRadarSection" spacing="4" visible="false" managed="false"
                  styleClass="exploration-exobio-radar-section"/>
            <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" 
                        styleClass="exploration-bodies-list-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <VBox fx:id="bodiesListContainer" spacing="3" styleClass="exploration-bodies-list-container"/>
            </ScrollPane>
        </VBox>
        
        <!-- Zone d'affichage des corps célestes (AnchorPane : JSON ancré haut/droite/bas pour toute la hauteur) -->
        <AnchorPane HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <ScrollPane fx:id="bodiesScrollPane" styleClass="exploration-visual-scroll"
                        fitToWidth="false" fitToHeight="false"
                        minHeight="300" prefWidth="800" prefHeight="450"
                        hbarPolicy="NEVER" vbarPolicy="NEVER"
                        AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                        AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
                <Group fx:id="bodiesGroup">
                    <Pane fx:id="bodiesPane" styleClass="exploration-visual-pane"
                          minHeight="300" prefWidth="800" prefHeight="450"
                          maxWidth="800" maxHeight="600"/>
                </Group>
            </ScrollPane>
            <VBox alignment="BOTTOM_LEFT" maxWidth="260.0" spacing="8.0" pickOnBounds="false"
                  AnchorPane.bottomAnchor="8.0" AnchorPane.leftAnchor="8.0">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label fx:id="spacingHorizontalLabel" styleClass="colonisation-detail-label" text="Horizontal spacing" minWidth="120.0" prefWidth="120.0"/>
                            <Slider fx:id="spacingHorizontalSlider" max="1.875" min="0.4" value="1.1375" HBox.hgrow="ALWAYS" styleClass="system-view-spacing-slider"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label fx:id="spacingVerticalLabel" styleClass="colonisation-detail-label" text="Vertical spacing" minWidth="120.0" prefWidth="120.0"/>
                            <Slider fx:id="spacingVerticalSlider" max="1.875" min="0.4" value="1.1375" HBox.hgrow="ALWAYS" styleClass="system-view-spacing-slider"/>
                        </HBox>
                    </VBox>
                    <Button fx:id="resetViewParametersButton" text="⟳" styleClass="elite-nav-button"/>
                </HBox>
            </VBox>
            <!-- Fenêtre JSON : overlay pleine hauteur utile à droite -->
            <VBox fx:id="jsonDetailPanel" pickOnBounds="true"
                  styleClass="colonisation-column,colonisation-detail-column,exploration-json-side-panel"
                  visible="false" managed="false"
                  minWidth="360" prefWidth="440" maxWidth="480" minHeight="200"
                  AnchorPane.topAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.bottomAnchor="10.0">
                <HBox spacing="10" alignment="TOP_LEFT" styleClass="colonisation-detail-window-header,exploration-json-window-header-row">
                    <Label fx:id="jsonBodyNameLabel" text="Détails JSON" styleClass="colonisation-section-subtitle"
                           wrapText="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="jsonSpanshSourceTagLabel" text="SPANSH" visible="false" managed="false"
                           styleClass="exploration-json-source-tag"/>
                    <Button fx:id="closeJsonPanelButton" mnemonicParsing="false" focusTraversable="false"
                            text="X" styleClass="colonisation-panel-fold-button"
                            onAction="#closeJsonPanel"/>
                </HBox>
                <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS"
                            styleClass="colonisation-map-detail-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <TreeView fx:id="jsonTreeView" styleClass="exploration-json-tree"
                              showRoot="true" VBox.vgrow="ALWAYS"/>
                </ScrollPane>
            </VBox>
        </AnchorPane>
    </HBox>
</VBox>

